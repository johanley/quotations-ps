% descr encoding-vector new-font-name old-font-name 
% Create a new font from an existing one, using the given encoding vector instead of the PostScript standard encoding vector.
/re-encode-font {
  [/descr /encoding-vector /new-font-name /old-font-name] {
    old-font-name findfont % font
    dup length dict % font dict
    begin  % font
      % copy everything in the old font's dict  - except for the FID (unique id ); needed only in Lang Level 1
      { 1 index /FID ne {def}{pop pop} ifelse } forall
      /Encoding encoding-vector def % replace two entries in this dict
      /FontName new-font-name def
      currentdict  % push this font-dict back onto the operand stack; new-dict
    end
    new-font-name exch % new-font-name new-dict
    definefont  % internally sets a FID (font-id) for the new font
    %pop % remove the new font object from the operand stack
    1 dict begin
      (Re-encoded font.) == 
      descr ==
      % log info for the new font
      /the-new-font exch def
      (/FontName:) == 
      the-new-font /FontName get == 
      (/FontType:) == 
      the-new-font /FontType get == 
      (/FontMatrix scale-x:) == 
      the-new-font /FontMatrix get 0 get ==
    end
  } def-tmp
} bind def


% font-name percent
% The font name as a /my-fonts /lookup key, and the percentage of the DEFAULT font-size.
% Selects a new font. Updates my-fonts /current.
/use-font {
  [/font-name /percent] {
    my-fonts /lookup get font-name known {
      my-fonts /lookup get  font-name get 
      my-fonts /default-size get  percent pct
      selectfont
      
      my-fonts /current get /name font-name put
      my-fonts /current get /percent percent put
    } {
     (DUDE, unexpected font name, not known to /my-fonts /lookup.) ==
     str ==
    }ifelse
  } def-tmp
  % my-fonts /default-size get 
  % exch pct
  % use-another-font
} bind def


% font-name percent
% The font name as a /my-fonts /lookup key, and the percentage of the CURRENT font-size.
% Sets the current font.
% SHOULD THIS BE REMOVED? 
/r-use-font {
  my-fonts /current get /percent get  pct % a percent of a percent
  use-font
} bind def


% Return the current absolute font size.
% The returned value may be a rounded value, slightly different from the expected value.
% (This proc doesn't use /my-fonts.)
% WARNING: this has only been tested with Type 1, Type 2, and Type 42 fonts.
% WARNING: this assumes the font has no weird distortions in its /FontMatrix.
/current-font-size {
  % the font-size is part of the font-matrix
  % this depends on the fontmatrix, which in turn depends on the fonttype
  currentfont /FontMatrix get 0 get
  currentfont /FontType get 2 le {
    % Adobe Type 1 and 2 fonts have a FontMatrix [0.001 0 0 0.001 0 0], not [1 0 0 1 0 0]
    1000 mul
  } if
  % DO ANY OTHER FONT TYPES HAVE A FONT MATRIX DIFFERENT FROM [1 0 0 1 0 0]?
} bind def