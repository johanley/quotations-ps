
(base.ps) using

% ENCODE/INITIALIZE THE FONTS YOU WANT TO USE, AND QUICKLY SWITCH BETWEEN THEM.
%
% Usually, you will re-encode your fonts. 
% If you do that, then the textual encoding of your PostScript files should use the same encoding.
%
% This file creates a dict named /my-fonts in the currentdict for holding font information:
% << 
%  /default-size 12 
%  /lookup << (regular) /MyRegular (italic) /MyItalic >>
%  /current << /name (regular) /percent 120 >>
% >>
% In this example, /MyRegular and /MyItalic are examples of re-encoded fonts.
% The first two items are meant to be read-only after they are initially set.
%
% The /my-fonts dict exists to let you:
%  - refer to actual fonts indirectly; if they change, they are changed in one place
%  - use percentage-of-default-size instead of absolute sizes
%
% You usually need to tell your tools where to find fonts on your system.
% For Ghostscript, you can:
%    - set the GS_FONTPATH environment variable
%    - set the '-sFONTPATH=' command line switch.
% On Windows OS, fonts are usually in C:\Windows\Fonts


% <<(name) font>> default-size 
% CALL UPON STARTUP. 
% Set up your collection of (usually re-encoded) fonts that you'll be using in the document.
% The keys used in the dict are strings that you pass to procs defined below.
/init-my-fonts {
  /my-default-size defi
  /my-lookup defi
  /my-fonts << 
    /default-size my-default-size 
    /lookup my-lookup 
    /current << >> % empty to start with
  >> def
  /my-lookup discard
  /my-default-size discard
} bind def


% new-font-name old-font-name 
% Create a new font from an existing one, which uses the ISOLatin1Encoding instead of the standard PostScript encoding vector.
% Calling this allows (almost all) accented characters in West European languages to be treated as any other character.
/latinize {
  (ISOLatin-1)
  ISOLatin1Encoding 
  4 2 roll
  re-encode-font
} bind def


