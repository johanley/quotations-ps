%!PS

(using.ps) run
(base.ps) using
(debug.ps) using
(fonts.ps) using
(strings.ps) using
(text-align.ps) using

/inch {72 mul} bind def

% pale yellow
/set-background-color {
  0 0.06 0.22 0.08 setcmykcolor
} bind def

% deep dark blue
/set-foreground-color {
  0.96 0.96 0 0.79 setcmykcolor
} bind def

% [[xy]]
% The caller will need to set the origin and scale to suitable values, using trial and error.
/draw-star-line {
  newpath
  /is-first? true def
  {
    aload pop % x y
    is-first? { moveto } {lineto } ifelse
    /is-first? false def
  } forall % points [x y]
  stroke
} bind def

% x y stellar-mag
% two circles at the given location
% first in the background color, then in the foreground with a smaller radius
% this will give a pleasing effect when drawing star-points after the star-lines
/draw-star-point {
  newpath
  [/x /y /stellar-mag] {
    %/radius stellar-mag -1 mul 7 add def
    /radius stellar-mag 2.5 gt {0.30} {0.45} ifelse  def
    set-background-color
    x y radius 0 360 arc % to 'erase' star-lines a wee bit around the star
    fill
    set-foreground-color
    x y radius 0.7 mul 0 360 arc
    fill
  } def-tmp
} bind def

% WARNING: MUST MATCH SETTINGS IN book.ps
/trim-width  6 inch  def % that is, the INTERIOR pages
/trim-height 9 inch def

/bleed 0.125 inch  def % industry standard is 1/8" bleed on all sides
/spine 0.5 inch  def
/cover-width trim-width bleed add  2 mul  spine add def
/cover-height trim-height bleed 2 mul add def
<<
  /PageSize [cover-width cover-height]
>> setpagedevice  
<< /NeverEmbed [ ] >> setdistillerparams  % always embed fonts
true setstrokeadjust  % minimizes off-by-one-pixel line issues

%C:\Users\Owner\AppData\Local\Microsoft\Windows\Fonts
/MyRegular /GaramondPremrPro latinize
<< 
  (regular) /MyRegular
>>
12 % default font size 
init-my-fonts

set-background-color
0 0 cover-width cover-height rectstroke
0 0 cover-width cover-height rectfill

set-foreground-color
(regular) 850 use-font  

% spine-y Norman
(regular) 200 use-font  
gsave 
  bleed trim-width add spine 2 div add  
  bleed  
  translate 
  
  0
  trim-height 70 pct moveto 
  (Q) show-ctr-x
grestore


% front cover: a drawing
gsave 
  % put the origin near the center of the drawing
  bleed  trim-width add  spine add  trim-width 2 div add
  cover-height 55 pct  
  translate 

  % manually tweak the scale  
  7 dup scale  
  0.2 setlinewidth

  % draw a well-known constellation, as simple lines and dots  
  % no labels are used here, just the basic shape
  (constellaton-data-8859-1/orion.ps) run
grestore


% back cover: a drawing
gsave 
  % put the origin near the center of the drawing
  bleed  trim-width 2 div add
  cover-height 55 pct  
  translate 

  % manually tweak the scale  
  7 dup scale  
  0.2 setlinewidth

  % draw a well-known constellation, as simple lines and dots  
  % no labels are used here, just the basic shape
  (constellaton-data-8859-1/orion.ps) run
grestore


  
showpage

