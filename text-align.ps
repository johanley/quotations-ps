
% TEXT DIMENSIONS, AND TEXT ALIGNMENT WITH RESPECT TO THE CURRENTPOINT.
% The dimensions of text depend on the current font.
%
% Note that vertical alignment can often give mediocre results: the presence or absence of 
% ascenders/descenders can change the relative vertical position of text.

% str -> num num 
% Return the width/height (dx, dy) of the given text (in the current font).
% This is useful for centering in various ways
% https://stackoverflow.com/questions/3618194/how-to-determine-string-height-in-postscript luser droog
/text-dim {
  gsave
    0 0 moveto % a temporary currentpoint
    % the bounding box of the text
    false charpath flattenpath pathbbox % x0 y0 x1 y1
  grestore
  3 -1 roll sub % x0 x1 dy
  3 1 roll sub % dy -dx
  -1 mul % dy dx
  exch % dx dy
} bind def

% str -> num
% Return the width of the given string in the current font.
/text-width {
  text-dim % dx dy
  pop % dx
} bind def

% str -> num
% Return the height of the given string in the current font.
/text-height {
  text-dim % dx dy
  exch pop % dy 
} bind def

% num -> num
% Return a multiple of the height of small 'x' in the current font.
/ex {
 (x) text-height mul
} bind def

% num -> num
% Return a multiple of the height of capital 'M' in the current font.
/em {
 (M) text-height mul
} bind def

% -- ALIGN TEXT IN VARIOUS WAYS:

% str 
% Show text centered horizontally at the currentpoint.
/show-ctr-x {
  dup text-dim pop % text dx
  -2 div % text -dx/2
  0 rmoveto % text
  show
} bind def

% str
% Show text centered vertically at the currentpoint.
% WARNING: centering text vertically can give mediocre results (variations in ascenders, descenders etc.)
/show-ctr-y {
  dup text-dim exch pop % text dy
  -2 div % text -dy/2
  0 exch rmoveto % text
  show
} bind def

% str
% Show text centered horizontally AND vertically at the currentpoint, and show it.
% WARNING: centering text vertically can give mediocre results (variations in ascenders, descenders etc.)
/show-ctr-xy {
  dup text-dim % text dx dy
  -2 div % text dx -dy/2
  exch % text -dy/2 dx
  -2 div exch % text -dx/2 -dy/2
  rmoveto % text
  show
} bind def

% text 
% Show text right-aligned at the currentpoint.
/show-right-align {
  dup text-dim pop % text dx
  -1 mul % text -dx
  0 rmoveto % text
  show
} bind def

% text 
% Show text centered vertically at the currentpoint, and right-aligned.
% WARNING: centering text vertically can give mediocre results (variations in ascenders, descenders etc.)
/show-right-align-ctr-y {
  dup text-dim % text dx dy
  -0.5 mul % text dx -dy/2
  exch neg % text -dy/2 -dx
  exch % text -dx -dy/2
  rmoveto % text
  show
} bind def

% str (ALL CAPS)
% Like /show, but temporarily rescales the current font to make a good approximation 
% of the small-caps style. This should really only be used if you have no access to a 
% actual small-caps typeface.
% Derived from the 'Tutorial and Cookbook':
% https://archive.org/details/PSBlueBook/page/181/mode/2up?view=theater
/show-small-caps { 
    gsave
      small-caps-font
      show         % show the string with a temp small-caps font
      currentpoint % ensure currentpoint behaves like 'show' (because grestore is about to revert it)
    grestore % the old font
    moveto   % the currentpoint (placed on the stack, above)
} bind def

% Distort the currentfont to give a fair approximation of a small-caps font.
% Derived from the 'Tutorial and Cookbook':
% https://archive.org/details/PSBlueBook/page/181/mode/2up?view=theater
% 
% This is used only when you DON'T have an explicit small-caps version of a font.
/small-caps-font { 
  3 dict begin    
    /M 1 em def 
    /x 1 ex def 
    % (x + (M-x)/3) / M
    /y-scale x M x sub 3 div add M div def % the calc for the y-rescaling
    % 90 percent in the x-direction, variable for the y-direction
    currentfont [.9 0 0 y-scale 0 0] makefont setfont  
  end 
} bind def
