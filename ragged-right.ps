%!PS-Adobe-3.0
%%Title: Ragged Right
%%Version: 1.0
%%Creator: John O'Hanley
%%CreationDate: 2026-02-28
%%LanguageLevel: 3.0
%%DocumentMedia: Plain 612.0 792.0 60 white ()
%%DocumentNeededResources: font Helvetica Helvetica-Bold Helvetica-Oblique
%%BoundingBox: 0 0 612 792
%%Orientation: Portrait 
%%Pages: 1
%%EndComments 

%%BeginDefaults 
%%EndDefaults

%%BeginProlog

% RENDER TEXT WITH A RAGGED-RIGHT MARGIN.
% Also implements a large initial capital letter (drop-cap).
% If that's removed, the implementation is simpler.

(../02.using/using.ps) run

(../01.base/base.ps) using
(../04.debug/debug.ps) using
(../05.font-management/fonts.ps) using
(../07.strings/strings.ps) using
(../08.text-align/text-align.ps) using

% initial-letter leading /left-limit /right-limit [atoms]
%
% (The literal name objects passed here are names of procs.)
% Render text in a ragged-right style.
% The [atoms] array contains strings and control codes, marked/executed in sequence: 
%    [/R (This is regular text. Here's a single word of) /B (bold) /R (text.)]
% The control codes are literal names of procs. They change font or currentposition. 
% The strings are chopped into single words (split on whitespace), and marked with the 'show' operator in the usual way.
%
% The mental model here is that of executing one 'atom' at a time. 
% An 'atom' is a single word or a small change-of-position. 
% This algorithm processes one word at a time. It doesn't change the width of the whitespace character.
%
% For each atom, probe-ahead tests are made for line-overflow (on the right) and page-overflow (on the bottom).
% INTERESTING: those tests are made versus the 'nulldevice', and make no mark upon the output.
% If your atoms change program-state, then a save-restore mechanism is in place such that the probe-ahead
% will only affect a temp, writeable copy of your program-state.
%
% The /left-limit and /right-limit procs map a y-value to a corresponding left-or-right boundary.
% Those limits can be fixed or dynamic; a dynamic style allows for text to wrap around an image (for example).
% 
% Before calling this proc, the BeginPage proc will have set the initial work-box for each page:
%  - translates the origin of the CTM near the bottom left of the page
%  - defines /wd and /ht for the width and height of the work-box
%  - moves to a currentpoint at the top-left of the work-box (0 ht moveto)
/text-flow-ragged-right {
  [/initial-letter /leading /left-limit /right-limit /atoms] {
    (in:text-flow-ragged-right) here
    initial-letter length 0 gt {
      initial-letter as-large-capital
    } if
    atoms { 
      dup
      type /nametype eq {
        (atom: name) here
        [] exch cvx process-atom % no args for these guys (at least for now)
      } {
        % otherwise it's a string
        (atom: words) here
        str-words {
          ( ) str-concat % trailing space (gap between words)
          1 array astore  {show} process-atom
        } forall
      } ifelse
    } forall
  } def-tmp
} bind def

% [args] proc
/process-atom {
  [/args /proc-literal] {
    % probe the resulting position
    % possibly make changes to the currentposition before executing the atom
    args aload pop   
    % hacky: code specific to show-ing strings (should I just pass an arg for that?)
    args length 1 eq {
      args 0 get type /stringtype eq {
        str-trim % remove the trailing space from the arg 
      } if
    } if 
    /proc-literal   probe-ahead % x y
    dup % x y y 
    0 lt {
      (overflow: page) here
      pop pop % discard x y 
      NEW-PAGE
    } { % x y
      right-limit sub 
      /deviation defi 
      /new-line? deviation 0 gt def % line overflow
      new-line? {
        args length 1 eq {
          % hacky: this check is used to identify the use of /show with a word.
          % probe iff the deviation is more than 1/2 the word's width.
          % this reduces the jaggedness on the right by nearly 50%.
          deviation   args 0 get stringwidth pop 2 div   lt {
            (retain on the same line) here
            /new-line? false def
          } if 
        } if
      } if
      new-line? {
         /NEW-LINE probe-ahead % x y 
         exch pop % y 
         0 lt {
           (overflow: page) here
           NEW-PAGE
         } {
           (overflow: line) here
           NEW-LINE
         } ifelse
      } if
    } ifelse
    % finally, execute the atom at the correct position 
    args aload pop proc-literal
  } def-tmp
} bind def

% /proc-literal -> x y 
% Test how an atom changes the currentposition, by using it on nulldevice (with no change to the real document).
% If the proc has args, then the caller must place them on the operand stack.
%
% Occasionally, your atoms will need to alter state in your program (side effects).
% In that case, use the save-restore mechanism implemented below, to ensure that probe-ahead operations 
% interact only with a temp, writeable copy of the program-state.
/probe-ahead {
  save-program-state
  gsave % the currentpoint
  4 dict begin 
    % using the nulldevice ensures no effect on the actual page.
    % it has the default CTM, so it can only tell us dx and dy, not x and y
    nulldevice 
    currentpoint 
    [/x0 /y0] defi
    cvx exec 
    currentpoint 
    [/x1 /y1] defi
    y1 y0 sub % dy
    x1 x0 sub % dx
  end
  grestore % back to the 'real' currentpoint
  % now add dx dy to the actual x and y
  currentpoint % dy dx x y
  4 1 roll % y dy dx x 
  add % y dy xnew
  3 1 roll % xnew y dy
  add % xnew ynew
  restore-program-state
} bind def

% Returns true iff the nulldevice is currently in effect.
/probing-ahead? {
  currentpagedevice length 0 eq
} bind def

% y -> x-right
/right-limit-fixed { pop wd } bind def

% y -> x-left
/left-limit-fixed { pop 0 } bind def

% y -> x-left
% For the first few lines, indent a little bit, to make room for the big initial letter.
/left-limit-init-cap {
  pop
  0  % default
  % IMPORTANT: use actions/operators here that search the dict stack TOP-DOWN, to implement 
  % the save-restore mechanism. 
  % Here, the 'real' data lives in userdict, and a 'temp/probing' version of the data 
  % lives in a dict higher than userdict.
  init-cap-lines 0 gt {   % read: name look-up is top-down (as usual)
    wd 7.5 pct add
    /init-cap-lines  init-cap-lines 1 sub   store % write: 'store' has top-down logic
  } if
} bind def

% At the start of probe-ahead, save program state that might be changed by an atom's implementation.
/save-program-state {
  1 dict begin
  % copy your program-state from a lower dict into the new current dict
  /init-cap-lines  /init-cap-lines load  def   % 'load' has top-down behaviour
} bind def

% At the end of probe-ahead, restore program state that might be changed by an atom's implementation.
/restore-program-state {
  end
} bind def

% this will call /BeginPage (a configured proc in the device-directory)
/NEW-PAGE {
  (new page...) here
  showpage
} bind def

% Move the currentpoint to the start of the next line.
% Move down using the 'leading'.
/NEW-LINE {
  (crlf...) here
  currentpoint ht eq  exch 0 eq  and {
    % y = ht and x = 0
    % top of the page, so don't do anything! 
    % it would just leave a blank line
    (crlf is a no-op: at the top-left of an empty page) here
  } {
    currentpoint exch pop % y
    left-limit % x-left
    currentpoint exch pop % x-left y
    leading sub % x-left y-down
    moveto  
  } ifelse
} bind def

% Regular font.
/R { (regular) 100 use-font } bind def

% Italic font.
/I { (italic) 100 use-font } bind def

% Bold font.
/B { (bold) 100 use-font } bind def

% Start a new paragraph. 
/P {
  NEW-LINE 
  2 em 0 rmoveto % indentation
} bind def

% letter
% Show a single letter as a large capital (drop caps).
% Arrange the placement such that subsequent regular text aligns with the top of the letter.
/as-large-capital {
  [/letter] {
    (regular) 100 use-font 
    /x-ht 1 ex def
    (regular) 400 use-font 
    /ltr-ht letter text-height def
    /dy ltr-ht x-ht sub def
    0 dy neg rmoveto
    letter show  % with no trailing space
    0 dy rmoveto 
  } def-tmp
} bind def

% int - number of times showpage has been called: 0, 1,...
% The passed int can be used to provide a page number.
% For each new page, the initgraphics operator is called; that resets many items, 
% including the CTM, path, and currentpoint. The font is not affected, however.
/start-new-page {
  pop
  (Starting new page...) here
  % the work-box needs to be re-set for each new page
  wd 10 pct   ht 5 pct translate % bottom left of the work-box
  0 ht moveto % where the text will start
} bind def

%%EndProlog

%%BeginSetup               
  /page-width  8.5 72 mul def
  /page-height 11 72 mul def 
  /wd page-width 80 pct def   
  /ht page-height 90 pct def   
  <<
    /PageSize [page-width  page-height]
    /BeginPage {start-new-page}  % the proc executed with each new page
  >> setpagedevice  
  << /NeverEmbed [ ] >> setdistillerparams  % always embed fonts
  true setstrokeadjust  % minimizes off-by-one-pixel line issues

  /MyRegular /Helvetica latinize
  /MyBold /Helvetica-Bold latinize
  /MyItalic /Helvetica-Oblique latinize
  << 
    (regular) /MyRegular
    (bold) /MyBold
    (italic) /MyItalic
  >>
  page-height 1.5 pct 
  init-my-fonts
%%EndSetup 

%%Page: 1 1
%%BeginPageSetup 
 %/pgsave save def     
%%EndPageSetup

  (regular) 100 use-font
  
  0 wd pct ht 85 pct moveto
  % this lives in userdict; 
  % a temporary, writeable copy is created in a higher dict when probe-ahead is called
  /init-cap-lines 0 def 
  
  ()   % no large initial letter
  2.5 em  % this needs a current font
  {left-limit-fixed}  % where to start a line 
  {right-limit-fixed} % where to end a line 
  [ % array of atoms - control codes and text 
   /R (An excerpt from) /I (On Bullshit) /R (by Harry G. Frankfurt \(Princeton University Press, 2005\):)
  ]
  text-flow-ragged-right 

  
  0 wd pct ht 70 pct moveto
  /init-cap-lines 1 def

  (O)   % the initial letter of the text is rendered in a unique way
  2.5 em  
  {left-limit-init-cap} % indentation for the large initial letter
  {right-limit-fixed} % where to end a line 
  [ % array of atoms - control codes and text 
/B(ne of the most salient features of our culture is that there is so much bullshit.) /R (Everyone knows this. \
Each of us contributes his share. But we tend to take the situation for granted. Most people are rather confident of their \
ability to recognize bullshit and to avoid being taken in by it. So the phenomenon has not aroused much deliberate concern, nor \
attracted much sustained inquiry.) 
  /P (In consequence, we have no clear understanding of what bullshit is, why there is so much of it, \
or what function it serves. And we lack a conscientiously developed appreciation of what it means to us. In other words, we have \
no theory. I propose to begin the development of a theoretical understanding of bullshit, mainly by providing some tentative and \
exploratory philosophical analysis. I shall not consider the rhetorical uses and misuses of bullshit. My aim is simply to give a \
rough account of what bullshit is and what it is not - or (putting it somewhat differently) to articulate, more or less sketchily \
the structure of its concept.) 
  /P (Any suggestion about what conditions are logically both necessary and sufficient for the constitution \
of bullshit is bound to be somewhat arbitrary. For one thing, the expression) /I (bullshit) 
/R (is often employed quite loosely - simply as a generic term of abuse, with no very specific literal meaning. \
For another, the phenomenon itself is so vast and amorphous that no crips and perspicuous analyisis of its concept can avoid \
being procrustean. Nonetheless it should be possible to say something helpful, even thought it is not likely to be decisive. \
Even the most basic and preliminary questions about bullshit remain, after all, not only unanswered but unasked.) 
  /P (So for as I'm aware, very little work has been done on this subject. I have not undertaken a survey of the literature, \
partly because I do not know how to go about it. To be sure, there is one quite obvious place to look - the) 
/I (Oxford English Dictionary.) 
/R(The) /I (OED) /R(has an entry for) /I(bullshit) 
/R (in the supplementary volumes, and it also has entries for various pertinent uses of the word) /I(bull) 
/R (and some related terms. I shall consider some of these entries in due course. I have not consulted dictionaries in \
languages other than English, because I do not know the words for bullshit or bull in any other language. Another worthwhile \
source is the title essay in) /I (The Prevalence of Humbug) /R (by Max Black. I am uncertain just how close in meaning the word) 
/I (humbug) /R (is to the word) /I (bullshit.) /R (Of course, the words are not freely and fully interchangeable; it is \
clear that they are used differently. But the difference appears on the whole to have more to do with considerations of gentility, \
and certain other rhetorical parameters, than with the strictly literal modes of significance that concern me most. It is more \
polite, as well as less intense, to say "Humbug!" than to say "Bullshit!" For the sake of this discussion, I shall assume that \
there is no other important difference between the two.)
  ]
  text-flow-ragged-right 

%pgsave restore
showpage
%%PageTrailer
%%Trailer    
%%EOF 