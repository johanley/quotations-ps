%!PS

(using.ps) run
(base.ps) using
(debug.ps) using
(fonts.ps) using
(strings.ps) using
(text-align.ps) using

/inch {72 mul} bind def

% pale yellow
/set-background-color {
  0 0.06 0.22 0.08 setcmykcolor
} bind def

% deep dark blue
/set-foreground-color {
  0.96 0.96 0 0.79 setcmykcolor
} bind def

% [[xy]]
% The caller will need to set the origin and scale to suitable values, using trial and error.
/draw-star-line {
  newpath
  /is-first? true def
  {
    aload pop % x y
    is-first? { moveto } {lineto } ifelse
    /is-first? false def
  } forall % points [x y]
  stroke
} bind def

% x y stellar-mag
% two circles at the given location
% first in the background color, then in the foreground with a smaller radius
% this will give a pleasing effect when drawing star-points after the star-lines
/draw-star-point {
  newpath
  [/x /y /stellar-mag] {
    %/radius stellar-mag -1 mul 7 add def
    /radius stellar-mag 2.5 gt {0.30} {0.45} ifelse  def
    set-background-color
    x y radius 0 360 arc % to 'erase' star-lines a wee bit around the star
    fill
    set-foreground-color
    x y radius 0.7 mul 0 360 arc
    fill
  } def-tmp
} bind def

% for lulu.com with a linen cover, you need a dust jacket with 'flaps'
%  20.438" wide, 9.75" high; 3.25" flaps; 2*6.625 main cover; 0.688 spine
% 
% for lulu.com with a case wrap:
% 14.438" wide = 2*6.875 main cover + 0.688 spine; 10.75" high;

% for lulu.com, dust jacket with flaps:
/total-width  20.438 inch  def 
/total-height 9.75 inch def

/flap 3.25 inch  def 
/spine 0.688 inch  def
/edge-to-middle-cover
  total-width 0.5 mul 
  spine 0.5 mul       sub 
  flap                add 
  0.5 mul
def
<<
  /PageSize [total-width total-height]
>> setpagedevice  
<< /NeverEmbed [ ] >> setdistillerparams  % always embed fonts
true setstrokeadjust  % minimizes off-by-one-pixel line issues

%C:\Users\Owner\AppData\Local\Microsoft\Windows\Fonts
/MyRegular /ACaslonPro-Regular latinize
<< 
  (regular) /MyRegular
>>
12 % default font size 
init-my-fonts

set-background-color
0 0 total-width total-height rectstroke
0 0 total-width total-height rectfill

set-foreground-color
(regular) 850 use-font  

% spine-y Norman
(regular) 200 use-font  
gsave 
  total-width 2 div  
  0 
  translate 
  
  0
  total-height 70 pct moveto 
  (Q) show-ctr-x
grestore


% back cover: a drawing
gsave 
  % put the origin near the center of the drawing
  edge-to-middle-cover
  total-height 55 pct  
  translate 

  % manually tweak the scale  
  7 dup scale  
  0.2 setlinewidth

  % draw a well-known constellation, as simple lines and dots  
  % no labels are used here, just the basic shape
  (constellaton-data-8859-1/orion.ps) run
grestore


% front cover: a drawing
gsave 
  % put the origin near the center of the drawing
  total-width edge-to-middle-cover sub spine 0.5 mul sub
  total-height 55 pct  
  translate 

  % manually tweak the scale  
  7 dup scale  
  0.2 setlinewidth

  % draw a well-known constellation, as simple lines and dots  
  % no labels are used here, just the basic shape
  (constellaton-data-8859-1/orion.ps) run
grestore


  
showpage

