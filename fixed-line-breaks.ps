%!PS-Adobe-3.0
%%Title: Fixed Line Breaks
%%Version: 1.0
%%Creator: John O'Hanley
%%CreationDate: 2026-02-25
%%LanguageLevel: 3.0
%%DocumentMedia: Plain 612.0 792.0 60 white ()
%%DocumentNeededResources: font Helvetica Helvetica-Bold Helvetica-Oblique Consolas Consolas-Italic
%%BoundingBox: 0 0 612 792
%%Orientation: Portrait 
%%Pages: 4
%%EndComments 

%%BeginDefaults 
%%EndDefaults

%%BeginProlog

% RENDER TEXT WITH KNOWN LINE BREAKS.
% This is the simplest case for laying out lines of text on a page.

(../02.using/using.ps) run

(../01.base/base.ps) using
(../04.debug/debug.ps) using
(../05.font-management/fonts.ps) using
(../07.strings/strings.ps) using
(../08.text-align/text-align.ps) using

% dict
% Render multiple lines of text with fixed line breaks, using the current font.
% The current point must exist. 
% The currentpoint.x is retained for all lines.
% New pages are created if the text extends beyond one page.
% SEE EXAMPLE DICT BELOW.
/fixed-line-breaks-1-font {
  4 dict begin
    { def } forall 
    currentpoint pop /x0 defi
    lines str-lines {
      show % the whole line
      advance-the-line % might cause a new page
    } forall % lines
  end
} bind def

% New-line: set the starting position for the next line.
% This can cause a new-page as well.
/advance-the-line {
  x0 % always align with the original x-position
  currentpoint exch pop % x0 y 
  leading sub % x0 y-minus-one-line
  dup 0 lt {
    pop pop % discard the stack
    showpage % top-left of the next page, at x0 (see start-new-page)
  } {
    moveto
  } ifelse
} bind def

% int - number of times /showpage has been called: 0, 1,...
% The passed int can be used to provide a page number.
% For each new page, the initgraphics operator is called; that resets many items, 
% including the CTM, path, and currentpoint. The font is not affected, however.
% SEE SETPAGEDEVICE BELOW.
/start-new-page {
  pop
  (Starting new page...) here
  % the work-box needs to be re-set for each new page
  wd 10 pct   ht 5 pct translate % origin is bottom left of the work-box
  0  currentdict /x0 known {x0 add (indent with x0)== }if 
  ht 
  moveto % the top-left of the work-box (maybe indented to x0)
} bind def

% dict
% Render multiple lines of text with fixed line breaks, with possibly multiple fonts per line.
% The current point must exist. 
% The currentpoint.x is retained for all lines.
% New pages are created if the text extends beyond one page.
% SEE EXAMPLE DICT BELOW.
/fixed-line-breaks-N-fonts {
  4 dict begin
    { def } forall 
    currentpoint pop /x0 defi
    lines { 
      % [procs]
      % a single line is  an array of procs
      % one proc for each 'run' of contiguous text that shares one font
      { 
        exec 
      } forall % procs in a line
      advance-the-line
    } forall % lines
  end
} bind def

% leading [[line]]
%
% Each [line] array contains strings and control codes, marked/executed in sequence: 
%    [/R (This is regular text. This is one word of) /B (bold) /R (text.)]
% The control codes are literal-names of procs. They change the font.
% The strings are chopped into single words (split on whitespace), 
% and marked with the 'show' operator in the usual way.
%
% This algorithm doesn't change the width of the whitespace character.
% 
% Before calling this proc, the BeginPage proc will have set the initial work-box for each page:
%  - translates the origin of the CTM near the bottom left of the page
%  - defines /wd and /ht for the width and height of the work-box
%  - moves to a currentpoint at the top-left of the work-box (0 ht moveto)
/fixed-line-breaks-control-codes {
  2 dict begin
    { def } forall 
    currentpoint pop /x0 defi
    lines { 
       % an [] of strings and control codes
      { dup
        type /nametype eq {
          cvx exec
        } {
          show % the string on one line
        } ifelse
      } forall % parts of the line
      advance-the-line
    } forall % lines
  end
} bind def

% str
% Render as small-caps text. 
/CAP {
  (regular) 100 use-font 
  show-small-caps
} bind def

% str
% Regular text.
/REG {
  (regular) 100 use-font show
} bind def

% str
% Italic text.
/ITAL {
  (italic) 100 use-font show
} bind def

% str
% Text of program code. Uses a fixed-width font.
/CODE {
  (fixed-width) 80 use-font show
} bind def

% str
% A code comment. Uses a fixed-width font.
/COM {
  0.33 setcolor
  (fixed-width-italic) 80 use-font show
  0 setcolor
} bind def


% Curt 'control codes' for changing font.
% This is used by one of the implementations to make the input text more curt.

% Small-caps font, as a DISTORTION of the currentfont.
/SC {0 setcolor small-caps-font } bind def
% Regular font.
/R {0 setcolor (regular) 80 use-font } bind def
% Italic font.
/I {0 setcolor (italic) 80 use-font } bind def
% Font for rendering code.
/CD {0 setcolor (fixed-width) 80 use-font } bind def
% Font for rendering code comments.
/CM {0.33 setcolor (fixed-width-italic) 80 use-font } bind def

%%EndProlog

%%BeginSetup               
  /page-width  8.5 72 mul def
  /page-height 11 72 mul def
  /wd page-width 80 pct def   
  /ht page-height 90 pct def   
  <<
    /PageSize [page-width  page-height]
    /BeginPage {start-new-page}  % the proc executed with each new page
  >> setpagedevice  
  << /NeverEmbed [ ] >> setdistillerparams  % always embed fonts
  true setstrokeadjust  % minimizes off-by-one-pixel line issues

  /MyRegular /Helvetica latinize
  /MyCapital /Helvetica-Bold latinize
  /MyItalic /Helvetica-Oblique latinize
  /MyFixedWidth /Consolas latinize
  /MyFixedWidthItalic /Consolas-Italic latinize
  << 
    (regular) /MyRegular
    (capital) /MyCapital
    (italic) /MyItalic
    (fixed-width) /MyFixedWidth
    (fixed-width-italic) /MyFixedWidthItalic
  >>
  page-height 1.5 pct 
  init-my-fonts

%%EndSetup 

%%Page: 1 1
%%BeginPageSetup 
 /pgsave save def     
%%EndPageSetup


  wd 10 pct  ht 100 pct  moveto  % the lines all start at this currentpoint.x
  % WARNING: a font needs to be present for the leading calc to work below
  (fixed-width) 80 use-font  
  % this style uses procs for each contiguous run
  << 
    /leading 1.75 em  % this needs a font to be present!
    /lines [
      [ {(% x-pct y-pct)COM} ]
      [ {(% moveto, but expressed using percentages of)COM} ]
      [ {(% the /page-width and /page-height)COM}  ]
      [ {(/pmoveto {)CODE} ]
      [ {(  [/x-pct /y-pct] {)CODE} ]
      [ {(    page-width x-pct pct)CODE} ]
      [ {(    page-height y-pct pct)CODE} ]
      [ {(    moveto)CODE} {( % a new position)COM}]
      [ {(  } def-tmp)CODE} ]
      [ {(} bind def)CODE} ]
    ]
  >> fixed-line-breaks-N-fonts
  
  
  0 1.75 em 2 mul neg rmoveto  
  % this style uses 'control codes' to manage font changes
  << 
    /leading 1.75 em 
    /lines [
      [ /CM (% x-pct y-pct) ]
      [ (% moveto, but expressed using percentages of) ]
      [ (% the /page-width and /page-height) /CD ]
      [ (/pmoveto {) ]
      [ (  [/x-pct /y-pct] {) ]
      [ (    page-width x-pct pct) ]
      [ (    page-height y-pct pct) ]
      [ (    moveto) /CM ( % a new position) /CD ]
      [ (  } def-tmp) ]
      [ (} bind def)]
    ]
  >> fixed-line-breaks-control-codes

  
  (fixed-width) 80 use-font  
  0 1.75 em 3 mul neg rmoveto
  % this style is less attractive visually, but you can copy-paste the source code directly
  << 
    /leading 1.75 em  
    /lines   
(% moveto, but expressed using percentages of
% the /page-width and /page-height
/pmoveto {
  [/x-pct /y-pct] {
    page-width x-pct pct
    page-height y-pct pct
    moveto  % a new position
  } def-tmp
} bind def)
   >> fixed-line-breaks-1-font


  % This is tedious to enter.
  % Fancy Idea: temporarily redefine 'def' to take a proc-as-string; store the string; then cvx the string to make it a proc
  % That way the original string is available for documentation.
  0 1.75 em 2 mul neg rmoveto  
  << 
    /leading 1.75 em  
    /lines [
[{(% dict) COM}]
[{(% Render multiple lines of text with fixed line breaks, using the current font.) COM}]
[{(% The current point must exist.) COM} ]
[{(% The currentpoint.x is retained for all lines.) COM}]
[{(% New pages are created if the text extends beyond one page.) COM}]
 [{(% SEE EXAMPLE DICT BELOW.) COM}]
 [{(/fixed-line-breaks-1-font { ) CODE}]
 [{(  4 dict begin) CODE}]
 [{(    { def } forall ) CODE}]
 [{(    currentpoint pop /x0 defi) CODE}]
 [{(    lines str-lines {) CODE}]
 [{(      show) CODE} {( % the whole line) COM}]
 [{(      advance-the-line) CODE} { ( % might cause a new page) COM}]
[{(    } forall) CODE} {( % lines) COM}]
[{(  end) CODE}]
[{(} bind def) CODE}]
[{() CODE}]
[{(% New-line: set the starting position for the next line.) COM}]
[{(% This can cause a new-page as well.) COM}]
[{(/advance-the-line {) CODE}]
[{(  x0 ) CODE} {( % always align with the original x-position]) COM} ]
[{(  currentpoint exch pop) CODE} {( % x0 y ) COM}]
[{(  leading sub ) CODE} {( % x0 y-minus-one-line) COM}]
[{(  dup 0 lt {) CODE}]
[{(    pop pop) CODE} {( % discard the stack) COM}]
[{(    showpage) CODE} {( % top-left of the next page, at x0 (see start-new-page)) COM}]
[{(  } {) CODE}]
[{(    moveto) CODE}]
[{(  } ifelse) CODE}]
[{(} bind def) CODE}]
[{() CODE}]
[{(% int - number of times /showpage has been called: 0, 1,...) COM}]
[{(% The passed int can be used to provide a page number.) COM}]
[{(% For each new page, the initgraphics operator is called; that resets many items, ) COM}]
[{(% including the CTM, path, and currentpoint. The font is not affected, however.) COM}]
[{(/start-new-page {) CODE}]
[{(  pop) CODE}]
[{(  (Starting new page...) here) CODE}]
[{(  % the work-box needs to be re-set for each new page) COM}]
[{(  wd 10 pct   ht 5 pct translate ) CODE} {( % origin is bottom left of the work-box) COM}]
[{(  0  currentdict /x0 known {x0 add (indent with x0)== }if ) CODE}]
[{(  ht ) CODE}]
[{(  moveto ) CODE} {( % the top-left of the work-box (maybe indented to x0)) COM}]
[{(} bind def) CODE}]
  ]
  >> fixed-line-breaks-N-fonts
  
  % This is easier to enter (copy-paste), but less attractive visually.
  (fixed-width) 80 use-font  
  0 1.75 em 3 mul neg rmoveto
  << 
    /leading 1.75 em  
    /lines   
(% dict
% Render multiple lines of text with fixed line breaks, using the current font.
% The current point must exist. 
% The currentpoint.x is retained for all lines.
% New pages are created if the text extends beyond one page.
% SEE EXAMPLE DICT BELOW.
/fixed-line-breaks-1-font {
  4 dict begin
    { def } forall 
    currentpoint pop /x0 defi
    lines str-lines {
      show % the whole line
      advance-the-line % might cause a new page
    } forall % lines
  end
} bind def

% New-line: set the starting position for the next line.
% This can cause a new-page as well.
/advance-the-line {
  x0 % always align with the original x-position
  currentpoint exch pop % x0 y 
  leading sub % x0 y-minus-one-line
  dup 0 lt {
    pop pop % discard the stack
    showpage % top-left of the next page, at x0 (see start-new-page)
  } {
    moveto
  } ifelse
} bind def

% int - number of times /showpage has been called: 0, 1,...
% The passed int can be used to provide a page number.
% For each new page, the initgraphics operator is called; that resets many items, 
% including the CTM, path, and currentpoint. The font is not affected, however.
/start-new-page {
  pop
  (Starting new page...) here
  % the work-box needs to be re-set for each new page
  wd 10 pct   ht 5 pct translate % origin is bottom left of the work-box
  0  currentdict /x0 known {x0 add (indent with x0)== }if 
  ht 
  moveto % the top-left of the work-box (maybe indented to x0)
} bind def)    
   >> fixed-line-breaks-1-font
  
  
  (regular) 100 use-font


  0 1.75 em 2 mul neg rmoveto  
  << 
    /leading 1.75 em  
    /lines [
[{(SCENE II. The sea-coast.) REG}]
[{() REG}]
[{(Enter VIOLA, a Captain, and Sailors) ITAL}]
[{() REG}]
[{(VIOLA:)CAP}{( What country, friends, is this?) REG}]
[{(CAPTAIN:)CAP}{( This is Illyria, lady.) REG}]
[{(VIOLA:)CAP}{( And what should I do in Illyria?) REG}]
[{(My brother he is in Elysium.) REG}]
[{(Perchance he is not drown'd: what think you, sailors?) REG}]
[{(CAPTAIN:)CAP}{ ( It is perchance that you yourself were saved.) REG}]
[{(VIOLA:)CAP}{( O my poor brother! and so perchance may he be.) REG}]
[{(CAPTAIN:)CAP}{( True, madam: and, to comfort you with chance,) REG}]
[{(Assure yourself, after our ship did split,) REG}]
[{(When you and those poor number saved with you) REG}]
[{(Hung on our driving boat, I saw your brother,) REG}]
[{(Most provident in peril, bind himself,) REG}]
[{(Courage and hope both teaching him the practise,) REG}]
[{(To a strong mast that lived upon the sea;) REG}]
[{(Where, like Arion on the dolphin's back,) REG}]
[{(I saw him hold acquaintance with the waves) REG}]
[{(So long as I could see.) REG}]
[{(VIOLA:)CAP}{( For saying so, there's gold:) REG}]
[{(Mine own escape unfoldeth to my hope,) REG}]
[{(Whereto thy speech serves for authority,) REG}]
[{(The like of him. Know'st thou this country?) REG}]
[{(CAPTAIN:)CAP}{( Ay, madam, well; for I was bred and born) REG}]
[{(Not three hours' travel from this very place.) REG}]
[{(VIOLA:)CAP}{( Who governs here?) REG}]
[{(CAPTAIN:)CAP}{( A noble duke, in nature as in name.) REG}]
[{(VIOLA:)CAP}{( What is the name?) REG}]
[{(CAPTAIN:)CAP}{( Orsino.) REG}]
[{(VIOLA:)CAP}{( Orsino! I have heard my father name him:) REG}]
[{(He was a bachelor then.) REG}]
[{(CAPTAIN:)CAP}{( And so is now, or was so very late;) REG}]
[{(For but a month ago I went from hence,) REG}]
[{(And then 'twas fresh in murmur,--as, you know,) REG}]
[{(What great ones do the less will prattle of,--) REG}]
[{(That he did seek the love of fair Olivia.) REG}]
[{(VIOLA:)CAP}{( What's she?) REG}]
[{(CAPTAIN:)CAP}{( A virtuous maid, the daughter of a count) REG}]
[{(That died some twelvemonth since, then leaving her) REG}]
[{(In the protection of his son, her brother,) REG}]
[{(Who shortly also died: for whose dear love,) REG}]
[{(They say, she hath abjured the company) REG}]
[{(And sight of men.) REG}]
  ]
  >> fixed-line-breaks-N-fonts


  0 1.75 em 2 mul neg rmoveto  
  << 
    /leading 1.75 em  
    /lines   
(SCENE II. The sea-coast.

Enter VIOLA, a Captain, and Sailors

VIOLA: What country, friends, is this?
Captain: This is Illyria, lady.
VIOLA: And what should I do in Illyria?
My brother he is in Elysium.
Perchance he is not drown'd: what think you, sailors?
Captain: It is perchance that you yourself were saved.
VIOLA: O my poor brother! and so perchance may he be.
Captain: True, madam: and, to comfort you with chance,
Assure yourself, after our ship did split,
When you and those poor number saved with you
Hung on our driving boat, I saw your brother,
Most provident in peril, bind himself,
Courage and hope both teaching him the practise,
To a strong mast that lived upon the sea;
Where, like Arion on the dolphin's back,
I saw him hold acquaintance with the waves
So long as I could see.
VIOLA: For saying so, there's gold:
Mine own escape unfoldeth to my hope,
Whereto thy speech serves for authority,
The like of him. Know'st thou this country?
Captain: Ay, madam, well; for I was bred and born
Not three hours' travel from this very place.
VIOLA: Who governs here?
Captain: A noble duke, in nature as in name.
VIOLA: What is the name?
Captain: Orsino.
VIOLA: Orsino! I have heard my father name him:
He was a bachelor then.
Captain: And so is now, or was so very late;
For but a month ago I went from hence,
And then 'twas fresh in murmur,--as, you know,
What great ones do the less will prattle of,--
That he did seek the love of fair Olivia.
VIOLA: What's she?
Captain: A virtuous maid, the daughter of a count
That died some twelvemonth since, then leaving her
In the protection of his son, her brother,
Who shortly also died: for whose dear love,
They say, she hath abjured the company
And sight of men.)
  >> fixed-line-breaks-1-font


pgsave restore
showpage
%%PageTrailer
